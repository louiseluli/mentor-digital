# ============================================================
# SEGURANÇA — NUNCA commitar o .env real
# ============================================================

# Pseudonimização (obrigatório)
PSEUDONYMIZATION_PEPPER=
ANALYTICS_PEPPER=troque-por-outra-string-aleatoria

# Redis
REDIS_URL=redis://localhost:6379/0

# Telegram (preenchido no Micro-Batch 2.1)
TELEGRAM_BOT_TOKEN=
# Token secreto para validar webhook (gere com: python -c "import secrets; print(secrets.token_hex(32))")
WEBHOOK_SECRET=

# WhatsApp Cloud API (preenchido no Micro-Batch 7.1)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Plataforma Web
WEB_PLATFORM_URL=http://localhost:3000

# ── Análise de conteúdo (Fase 3) ─────────────────────────────────────────────

# Google Fact Check Tools API (3.1) — tier gratuito disponível
# Ativar em: console.cloud.google.com → Biblioteca → "Fact Check Tools API"
GOOGLE_API_KEY=

# VirusTotal (3.2) — tier gratuito: 4 req/min, 500/dia
# Criar conta em: virustotal.com → API Key (gratuito)
VIRUSTOTAL_API_KEY=

# Open PageRank (3.2) — tier gratuito: 100 req/dia
# Criar conta em: domcop.com/openpagerank/signup (gratuito)
OPENPAGERANK_API_KEY=

# Nota: RDAP e urlscan.io (pesquisa) são gratuitos e não precisam de chave.

# Ambiente
ENVIRONMENT=development

# CORS — origens permitidas pela API (vírgula-separado)
# Dev: http://localhost:3000 (default automático se não definido)
# Prod: URL real do Vercel
ALLOWED_ORIGINS=http://localhost:3000
